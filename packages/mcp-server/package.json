{
  "name": "@cowork-tasks/mcp-server",
  "version": "0.4.3",
  "description": "MCP server for Cowork Tasks - exposes the task store to the live artifact and the task-extractor agent.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cowork-tasks-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
